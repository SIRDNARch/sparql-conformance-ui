# Server Configuration
# Copy this file to .env and fill in the values

# ===================
# Server Settings
# ===================
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Docker host port mappings (compose)
PUBLIC_WEB_PORT=8080
PUBLIC_UPLOAD_PORT=3001
PRIVATE_WEB_PORT=8081

# Frontend path settings
# Root deployment (default): /
# Subpath deployment example: /website/
VITE_BASE_PATH=/

# API base for frontend requests.
# Leave as /api for default reverse-proxy setup.
# Optional override (example): /website/api
VITE_API_BASE_URL=/api

# Public website origin used by API containers for WEBSITE_URL/CORS defaults
# Root deployment example: https://abc.com
PUBLIC_WEBSITE_ORIGIN=http://localhost:8080

# Optional explicit CORS override for public profile.
# Leave empty to use PUBLIC_WEBSITE_ORIGIN automatically.
PUBLIC_CORS_ORIGIN=

# Private profile website origin and optional CORS override
PRIVATE_WEBSITE_ORIGIN=http://localhost:8081
PRIVATE_CORS_ORIGIN=

# Runtime mode
# public | private
APP_MODE=public

# Endpoint exposure
# all | read | upload
API_SURFACE=all

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Database
DB_PATH=conformance.db

# Private mode auto-import settings
# Used when APP_MODE=private
# LOCAL_RESULTS_DIR=/absolute/path/to/results
PRIVATE_AUTO_IMPORT=true

# ===================
# API Authentication
# ===================
API_KEY=your-secret-api-key-here

# ===================
# GitHub App Settings
# ===================
# These are required for PR comments and check runs
# Leave blank to disable GitHub App integration

# Your GitHub App's ID (found in app settings)
GITHUB_APP_ID=

# GitHub App private key (PEM format)
# Option 1: Paste the key directly (with \n for newlines)
# Option 2: Base64 encode the key: cat your-key.pem | base64 -w0
GITHUB_APP_PRIVATE_KEY=

# Installation ID for your GitHub App on the target repository
# Found in the URL when viewing the installation: /installations/{id}
GITHUB_INSTALLATION_ID=

# Default repository context for GitHub integration (recommended)
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# ===================
# UI Settings
# ===================
# URL to the conformance website (used in PR comments).
# Leave empty to auto-build from WEBSITE_ORIGIN + WEBSITE_BASE_PATH.
WEBSITE_URL=

# Used when WEBSITE_URL is empty (mainly for non-compose/server-only runs)
WEBSITE_ORIGIN=http://localhost:5173
WEBSITE_BASE_PATH=/

# ===================
# GitHub Check Settings
# ===================
# Name shown in the GitHub checks list
CHECK_NAME=SPARQL 1.1 Conformance Check

# Title shown in the check details
CHECK_TITLE=SPARQL Test Suite

# Title shown while the check is running
CHECK_RUNNING_TITLE=Running SPARQL Test Suite

# Bot username (used to identify and replace previous comments)
COMMENT_AUTHOR=conformance-test[bot]
