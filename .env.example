# Server Configuration
# Copy this file to .env and fill in the values:  cp .env.example .env

# ===================
# Server Settings
# ===================

# How chatty the logs are. Leave "info" for normal use; set "debug" to troubleshoot.
# Options: fatal | error | warn | info | debug | trace
# Optional (default: info)
LOG_LEVEL=info

# ===================
# Docker host ports
# ===================
# These are the ports on YOUR machine. Each maps to a fixed port inside the
# container.

# Public website — open it at http://localhost:<this>
# Optional (default: 8080)
PUBLIC_WEB_PORT=8080

# Public upload API — used by CI / manual uploads
# Optional (default: 3001)
PUBLIC_UPLOAD_PORT=3001

# Private-mode website
# Optional (default: 8081)
PRIVATE_WEB_PORT=8081

# ===================
# Frontend
# ===================

# The URL path the site is served under.
#   /                          -> root domain or subdomain (default)
#   /sparql-conformance-ui/ -> served under a subpath
# Baked in at BUILD time, so rebuild the web image after changing it:
#   docker compose --profile public build web
# Optional (default: /)
VITE_BASE_PATH=/

# ===================
# Private mode
# ===================

# Absolute path on your machine to the folder of result files to auto-import
# on startup (recursively finds .json / .json.gz / .json.bz2).
# Example: LOCAL_RESULTS_DIR=/home/me/results
# Required for private mode only.
# LOCAL_RESULTS_DIR=/absolute/path/to/results

# ===================
# API Authentication
# ===================

# Shared secret the public uploader checks on every upload (sent as the
# x-api-key header). Pick any strong random string — generate one with:
#   openssl rand -hex 32
# Required in public mode.
API_KEY=your-secret-api-key-here

# ===================
# GitHub App (optional)
# ===================
# Enables PR comments and check runs in public mode. Leave all blank to disable.
# Set up the app first — see SETUP.md section 6 for the full walkthrough.

# App ID: GitHub -> Settings -> Developer settings -> GitHub Apps -> your app
# -> General -> "App ID" field (a small number). Example: 123456
GITHUB_APP_ID=

# Private key (PEM): same General page -> "Private keys" -> "Generate a private
# key" downloads a .pem file. Paste its full contents here (with \n between
# lines), or base64-encode it and paste that:  base64 -w0 your-key.pem
GITHUB_APP_PRIVATE_KEY=

# Installation ID: open the app's installation settings — it's the number at the
# end of the URL:
#   Personal:     https://github.com/settings/installations/<INSTALLATION_ID>
#   Organization: https://github.com/organizations/<ORG>/settings/installations/<INSTALLATION_ID>
# Example: 987654321
GITHUB_INSTALLATION_ID=

# ===================
# UI Settings
# ===================

# Full public URL where the site is served. Used only to build links in GitHub
# PR comments / check runs, so only needed when the GitHub App is enabled.
# Example: WEBSITE_URL=https://qlever.dev/sparql-conformance-ui/
WEBSITE_URL=

# ===================
# GitHub check/comment names (optional cosmetics)
# ===================
# Defaults below are fine for most setups; override only to rename things.

# Name shown in the GitHub checks list
CHECK_NAME=SPARQL 1.1 Conformance Check

# Heading in the check details
CHECK_TITLE=SPARQL Test Suite

# Heading shown while the check is still running
CHECK_RUNNING_TITLE=Running SPARQL Test Suite

# Bot username used to find and replace the previous PR comment
COMMENT_AUTHOR=conformance-test[bot]
